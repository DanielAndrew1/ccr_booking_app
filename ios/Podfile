# Uncomment this line to define a global platform for your project
platform :ios, '15.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

def normalize_shell_script_arrays!
  pbxproj_path = File.expand_path('Runner.xcodeproj/project.pbxproj', __dir__)
  return unless File.exist?(pbxproj_path)

  source = File.read(pbxproj_path)
  return unless source.include?('shellScript = (')

  normalized = source.gsub(/shellScript = \(\n(.*?)\n\s*\);/m) do
    raw_lines = Regexp.last_match(1).lines.map(&:strip).reject(&:empty?)
    lines = raw_lines.map do |line|
      line = line.sub(/,\s*\z/, '')
      line = line[1..-2] if line.start_with?('"') && line.end_with?('"')
      line
    end

    escaped_script = lines
      .join("\\n")
      .gsub('\\', '\\\\')
      .gsub('"', '\"')

    "shellScript = \"#{escaped_script}\\n\";"
  end

  return if normalized == source

  File.write(pbxproj_path, normalized)
  puts 'Normalized shellScript entries in Runner.xcodeproj/project.pbxproj'
end

normalize_shell_script_arrays!

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    
    target.build_configurations.each do |config|
      # 1. Provide your Team ID to ALL pod targets and bundles
      config.build_settings['DEVELOPMENT_TEAM'] = '8TVX448JFQ'
      
      # 2. Fix Architecture issues for Simulators
      config.build_settings['EXPANDED_CODE_SIGN_IDENTITY'] = ""
      config.build_settings['CODE_SIGNING_REQUIRED'] = "NO"
      config.build_settings['CODE_SIGNING_ALLOWED'] = "YES"

      # 3. Specifically fix the Privacy Manifest bundle signing error
      # This ensures the nested bundles inherit the signing style
      config.build_settings['CODE_SIGN_STYLE'] = 'Automatic'
    end
  end
end
